{
  "displayName": "frolf-auth-failure-spike",
  "documentation": {
    "content": "Authentication failures are spiking and may indicate abuse.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "conditions": [
    {
      "displayName": "Auth failures above threshold",
      "conditionThreshold": {
        "filter": "resource.type = \"global\" AND metric.type = \"logging.googleapis.com/user/auth_failed_count\"",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_RATE"
          }
        ],
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.1,
        "duration": "300s",
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "1800s"
  },
  "enabled": true,
  "notificationChannels": [
    "projects/PROJECT_ID/notificationChannels/CHANNEL_ID"
  ]
}
